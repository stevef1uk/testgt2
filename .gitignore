# Gas Town rig .gitignore (clean baseline, May 2026)
# Tracks: user project files (SPEC.md, README.md, source code, ...).
# Ignores: every gt-agent/beads/dolt/runtime artifact + role worktree dirs.

# =============================================================================
# Gas Town runtime state (transient, never commit)
# =============================================================================
.runtime/
.claude/
.logs/
.archive/
.dolt-data/
.dolt/
.doltcfg/
__pycache__/
state.json
config.json
*.lock
*.flock
*.pid

# =============================================================================
# Agent-internal plumbing (Fix #95)
#
# These files are written by gt-agent / gt prime / script(1) and must
# never end up in user commits. SPEC.md and README.md are deliberately
# NOT in this list — those are user-authored content (the project
# contract / docs) and the polecat needs to READ them from its
# worktree at runtime.
# =============================================================================
.gt-agent
typescript
AGENTS.md
CLAUDE.md
CLAUDE.local.md
project_label
progress_report
gt-agent-state.json

# =============================================================================
# Role worktree directories (gt manages these — recreated on demand)
# =============================================================================
mayor/
witness/
refinery/
architect/
qa/
deacon/
planner/
mechanic/
crew/
polecats/
plugins/
settings/
.land-worktree/

# =============================================================================
# Bare-repo / git internals
# =============================================================================
.repo.git/

# =============================================================================
# Beads internal data (managed by bd)
# =============================================================================
.beads/

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
*~
*.swp
*.swo
.vscode/
.idea/
